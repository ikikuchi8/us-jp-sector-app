# ============================================================
# Application
# ============================================================
APP_ENV=development           # development | production
APP_DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# Database (PostgreSQL)
# ============================================================
POSTGRES_USER=sector_user
POSTGRES_PASSWORD=sector_pass
POSTGRES_DB=sector_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed from the above. Alternatively, set directly.
# DATABASE_URL=postgresql://sector_user:sector_pass@localhost:5432/sector_db

# ============================================================
# CORS (comma-separated origins)
# ============================================================
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Data fetching
# ============================================================
# Default data source for price fetching
PRICE_DATA_SOURCE=yfinance
